---
permalink: /feed.xml
# RSS 2.0. Hand-rolled (no jekyll-feed). Lists the most recent posts.
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | default: site.studio.logotype | xml_escape }}</title>
    <link>{{ '/' | absolute_url | xml_escape }}</link>
    <description>{{ site.description | default: '' | xml_escape }}</description>
    <language>{{ site.lang | default: 'en' }}</language>
    <atom:link href="{{ '/feed.xml' | absolute_url | xml_escape }}" rel="self" type="application/rss+xml"/>
    {%- for post in site.posts limit: 20 -%}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | absolute_url | xml_escape }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url | xml_escape }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <description>{{ post.excerpt | default: post.content | strip_html | strip_newlines | truncate: 400 | xml_escape }}</description>
    </item>
    {%- endfor -%}
  </channel>
</rss>
